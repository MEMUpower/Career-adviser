# Database Settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=career_advisor
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis Settings
REDIS_HOST=redis
REDIS_PORT=6379

# Security Settings
JWT_SECRET=supersecretjwtkeyforcareeradvisorappmvp2026
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM Provider Configuration
# Supported: "openai", "nvidia_nim", or "ollama"
LLM_PROVIDER=nvidia_nim
OPENAI_API_KEY=your-openai-api-key-here
NVIDIA_API_KEY=your-nvidia-api-key-here
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=minimaxai/minimax-m2.7
OLLAMA_BASE_URL=http://host.docker.internal:11434

# CareerNet OpenAPI
CAREERNET_API_KEY=your-careernet-api-key-here
CAREERNET_BASE_URL=https://www.career.go.kr

# App Settings
UPLOAD_DIR=/app/uploads
REPORT_DIR=/app/reports
LOG_LEVEL=info
